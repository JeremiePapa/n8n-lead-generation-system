      "name": "Wait",
      "webhookId": "e1e43c7a-e7e7-4ed7-b7c5-ab3b477f6dce"
    },
    {
      "parameters": {
        "jsCode": "return items.filter(i => {\n  const r =\n    i.json.result ||\n    i.json.body?.result ||\n    i.json.data?.result;\n\n  if (!r) return false;\n\n  const phone =\n    r.formatted_phone_number ||\n    r.international_phone_number ||\n    \"\";\n\n  const website = r.website || \"\";\n\n  const reviews =\n    typeof r.user_ratings_total === \"number\"\n      ? r.user_ratings_total\n      : null;\n\n  // Only drop if BOTH contact methods are missing\n  if (!phone && !website) return false;\n\n  // Only drop if reviews exist AND are very high (older clinics)\n  if (reviews !== null && reviews > 80) return false;\n\n  return true;\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1696,
        16
      ],
      "id": "ad4edfc4-6906-4c35-956e-f99bf70c819a",
      "name": "Code - Quality Filter"
    },
    {
      "parameters": {
        "jsCode": "return items.filter(i => {\n  const r =\n    i.json.result ||\n    i.json.body?.result ||\n    i.json.data?.result;\n\n  if (!r) return false;\n\n  // Require name\n  if (!r.name || r.name.trim() === \"\") return false;\n\n  // Require phone\n  if (!r.formatted_phone_number || r.formatted_phone_number.trim() === \"\")\n    return false;\n\n  return true;\n});\n"
      },
